---
import '../styles/global.css';
type Props = {
	title?: string;
	variant?: 'default' | 'store';
};

const { title = 'Rad Atelier', variant = 'default' } = Astro.props;
const loggedIn = !!Astro.locals.user;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		{
			variant === 'store' ? (
				<header class="sticky top-0 z-10 border-b border-muted bg-background px-[clamp(1rem,4vw,3rem)] py-4">
					<div class="mx-auto grid max-w-[90rem] grid-cols-1 grid-rows-[auto_auto_auto] justify-items-center gap-4 text-center md:grid-cols-[1fr_auto_1fr] md:grid-rows-none md:justify-items-stretch md:text-left">
						<a
							href="/"
							class="order-1 inline-flex items-center gap-2 font-serif text-inherit no-underline md:order-none md:justify-self-start"
						>
							<svg class="size-[22px] shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
								<path
									d="M12 22c4-6 8-10 8-15a8 8 0 1 0-16 0c0 5 4 9 8 15z"
									stroke="currentColor"
									stroke-width="1.5"
									stroke-linejoin="round"
								/>
								<path
									d="M12 16c-2-3-4-5-4-8a4 4 0 0 1 8 0c0 3-2 5-4 8z"
									fill="currentColor"
									opacity="0.35"
								/>
							</svg>
							<span class="text-[1.2rem] font-bold">Rad Atelier</span>
						</a>
						<nav
							class="order-3 flex flex-wrap items-center justify-center gap-x-[clamp(1rem,3vw,2.5rem)] gap-y-2 text-xs font-semibold uppercase tracking-[0.12em] text-primary md:order-none"
							aria-label="Store"
						>
							<a href="/" class="text-inherit no-underline hover:underline">
								Home
							</a>
							<a href="/#categories" class="text-inherit no-underline hover:underline">
								Catalogue
							</a>
							<a href="/#newsletter" class="text-inherit no-underline hover:underline">
								Contact
							</a>
						</nav>
						<div class="order-2 flex flex-wrap items-center justify-center gap-3 md:order-none md:justify-end md:justify-self-end">
							{loggedIn ? (
								<>
									<a
										href="/profile"
										class="inline-flex items-center justify-center border border-primary bg-primary px-[1.1rem] py-[0.55rem] font-sans text-[0.6875rem] font-bold uppercase tracking-[0.1em] text-background no-underline hover:opacity-[0.92]"
									>
										Profile
									</a>
									<form class="m-0 inline" method="post" action="/api/auth/logout">
										<input type="hidden" name="returnTo" value="/" />
										<button
											type="submit"
											class="cursor-pointer border-0 bg-transparent p-0 font-inherit text-xs font-semibold uppercase tracking-[0.06em] text-secondary underline"
										>
											Log out
										</button>
									</form>
								</>
							) : (
								<a
									href="/login"
									class="inline-flex items-center justify-center border border-primary bg-primary px-[1.1rem] py-[0.55rem] font-sans text-[0.6875rem] font-bold uppercase tracking-[0.1em] text-background no-underline hover:opacity-[0.92]"
								>
									Log in
								</a>
							)}
							<button
								type="button"
								class="inline-flex cursor-pointer items-center justify-center border-0 bg-transparent p-[0.35rem] text-primary no-underline hover:opacity-70"
								aria-label="Search"
							>
								<svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
									<path
										d="M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16zm9 2-4.35-4.35"
										stroke="currentColor"
										stroke-width="1.5"
										stroke-linecap="round"
									/>
								</svg>
							</button>
							<a
								href="#"
								class="inline-flex cursor-pointer items-center justify-center border-0 bg-transparent p-[0.35rem] text-primary no-underline hover:opacity-70"
								aria-label="Shopping cart"
							>
								<svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
									<path
										d="M6 6h15l-1.5 9h-12L6 6zm0 0L5 3H2"
										stroke="currentColor"
										stroke-width="1.5"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
									<circle cx="9" cy="20" r="1" fill="currentColor" />
									<circle cx="18" cy="20" r="1" fill="currentColor" />
								</svg>
							</a>
						</div>
					</div>
				</header>
			) : (
				<header class="sticky top-0 z-10 flex flex-wrap items-center justify-between gap-4 border-b border-muted bg-background px-[clamp(1rem,4vw,3rem)] py-5">
					<a href="/" class="font-serif text-xl font-bold no-underline">
						Rad Atelier
					</a>
					<nav class="flex flex-wrap items-center gap-5 text-[0.9375rem]" aria-label="Main">
						<a href="/#categories" class="no-underline hover:underline">
							Shop
						</a>
						<a href="/#featured" class="no-underline hover:underline">
							Featured
						</a>
						{loggedIn ? (
							<>
								<a href="/profile" class="no-underline hover:underline">
									Profile
								</a>
								<form class="m-0 inline" method="post" action="/api/auth/logout">
									<input type="hidden" name="returnTo" value="/" />
									<button
										type="submit"
										class="cursor-pointer border-0 bg-transparent p-0 font-inherit text-inherit underline hover:no-underline"
									>
										Log out
									</button>
								</form>
							</>
						) : (
							<a href="/login" class="no-underline hover:underline">
								Log in
							</a>
						)}
					</nav>
				</header>
			)
		}
		<slot />
	</body>
</html>
