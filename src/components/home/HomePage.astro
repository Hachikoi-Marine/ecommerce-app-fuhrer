---
import type { HomeCategoryCard, HomeFeaturedCard } from '../../lib/home-data';
import ProductCardGrid from '../store/ProductCardGrid.astro';
import { exampleImages } from '../../lib/example-images';

type Props = {
	heroImageUrl: string;
	heroImageAlt?: string;
	categories: HomeCategoryCard[];
	featuredProducts: HomeFeaturedCard[];
};

const {
	heroImageUrl,
	heroImageAlt = 'Store hero',
	categories,
	featuredProducts,
} = Astro.props;

const blog1 = exampleImages.blog1;
const blog2 = exampleImages.blog2;
---

<main>
	<section
		class="flex flex-col items-center gap-8 px-[clamp(1rem,4vw,3rem)] pb-0 pt-[clamp(2rem,5vw,4rem)] text-center"
		aria-labelledby="hero-heading"
	>
		<div class="max-w-[40rem]">
			<h1 id="hero-heading" class="mb-4 font-serif text-[clamp(2rem,5vw,3.25rem)] font-semibold leading-[1.15]">
				Find perfect plants for your home
			</h1>
			<p class="mb-7 text-[1.0625rem] text-secondary">Beautiful plants that encourage you to get creative.</p>
			<a
				class="inline-block cursor-pointer border border-primary bg-primary px-7 py-3.5 text-center font-sans text-[0.8125rem] font-semibold uppercase tracking-[0.08em] text-background no-underline"
				href="#featured"
			>
				Shop now
			</a>
		</div>
		<div class="mx-auto w-full max-w-6xl">
			<img
				class="block aspect-video w-full object-cover"
				src={heroImageUrl}
				alt={heroImageAlt}
				width="1800"
				height="900"
				loading="eager"
			/>
		</div>
	</section>

	<section
		id="categories"
		class="px-[clamp(1rem,4vw,3rem)] py-[clamp(3rem,8vw,5.5rem)]"
		aria-labelledby="categories-heading"
	>
		<h2
			id="categories-heading"
			class="mb-10 text-center font-serif text-[clamp(1.75rem,3vw,2.25rem)] font-semibold"
		>
			Categories
		</h2>
		{
			categories.length === 0 ? (
				<p class="mx-auto max-w-6xl text-center text-secondary">No categories yet.</p>
			) : (
				<div class="mx-auto grid max-w-6xl grid-cols-1 gap-[clamp(1rem,3vw,2rem)] md:grid-cols-3">
					{categories.map((cat) => (
						<a class="group text-inherit no-underline" href={cat.href}>
							<div class="aspect-[3/4] overflow-hidden">
								<img
									class="size-full object-cover object-center transition-transform duration-[350ms] ease-out group-hover:scale-[1.03]"
									src={cat.imageUrl}
									alt={cat.imageAlt}
									width="800"
									height="1000"
									loading="lazy"
								/>
							</div>
							<p class="mt-4 text-center font-serif text-lg">{cat.title}</p>
						</a>
					))}
				</div>
			)
		}
	</section>

	<section class="mx-auto max-w-3xl px-[clamp(1rem,4vw,3rem)] py-[clamp(3rem,8vw,5.5rem)] text-center" aria-label="Inspirational quote">
		<blockquote class="m-0 font-serif text-[clamp(1.25rem,2.5vw,1.5rem)] italic leading-snug">
			Love and work are to people what water and sunshine are to plants
		</blockquote>
	</section>

	<section
		id="featured"
		class="mx-auto grid max-w-6xl items-start gap-[clamp(2rem,5vw,4rem)] px-[clamp(1rem,4vw,3rem)] py-[clamp(3rem,8vw,5.5rem)] md:grid-cols-[1fr_1.1fr]"
		aria-labelledby="featured-heading"
	>
		<div>
			<h2 id="featured-heading" class="mb-4 font-serif text-[clamp(1.75rem,3vw,2.25rem)]">Featured</h2>
			<p class="mb-6 max-w-xs text-secondary">
				Handpicked listings from our catalog — open a piece for details and to add it to your cart.
			</p>
			<a
				class="inline-block cursor-pointer border border-primary bg-transparent px-7 py-3.5 text-center font-sans text-[0.8125rem] font-semibold uppercase tracking-[0.08em] text-primary no-underline"
				href="#categories"
			>
				Shop all favourites
			</a>
		</div>
		<ProductCardGrid products={featuredProducts} emptyMessage="No featured products yet." />
	</section>

	<section class="px-[clamp(1rem,4vw,3rem)] py-[clamp(3rem,8vw,5.5rem)]" aria-labelledby="blog-heading">
		<h2 id="blog-heading" class="sr-only">From the journal</h2>
		<div class="mx-auto grid max-w-6xl grid-cols-1 gap-[clamp(1rem,3vw,2rem)] md:grid-cols-2">
			<article>
				<div class="relative overflow-hidden">
					<img class="block aspect-[16/10] w-full object-cover" src={blog1} alt="" width="900" height="560" loading="lazy" />
					<div class="absolute left-4 top-4 bg-background px-3 py-2 text-[0.8125rem] text-primary">
						Written by Melissa Ball
					</div>
				</div>
				<div class="pt-4">
					<p class="mb-1.5 text-[0.8125rem] text-secondary">Edition 202</p>
					<h3 class="m-0 font-serif text-[clamp(1.125rem,2vw,1.35rem)] font-bold leading-snug">
						How to water your freaking plants so they don't die after one week
					</h3>
				</div>
			</article>
			<article>
				<div class="relative overflow-hidden">
					<img class="block aspect-[16/10] w-full object-cover" src={blog2} alt="" width="900" height="560" loading="lazy" />
					<div class="absolute left-4 top-4 bg-background px-3 py-2 text-[0.8125rem] text-primary">
						Written by Jesse Royce
					</div>
				</div>
				<div class="pt-4">
					<p class="mb-1.5 text-[0.8125rem] text-secondary">Edition 203</p>
					<h3 class="m-0 font-serif text-[clamp(1.125rem,2vw,1.35rem)] font-bold leading-snug">
						How to repot a Monstera without killing it and foster its growth
					</h3>
				</div>
			</article>
		</div>
	</section>

	<section
		id="newsletter"
		class="mx-auto max-w-2xl px-[clamp(1rem,4vw,3rem)] py-[clamp(3rem,8vw,5.5rem)] text-center"
		aria-labelledby="newsletter-heading"
	>
		<h2 id="newsletter-heading" class="mb-7 font-serif text-[clamp(1.25rem,2.5vw,1.5rem)] font-semibold leading-snug">
			Get 15% off your next order, subscribe to our newsletter
		</h2>
		<div class="flex flex-wrap items-stretch justify-center gap-3" role="group" aria-label="Newsletter signup">
			<label class="sr-only" for="newsletter-email">Email</label>
			<input
				id="newsletter-email"
				class="min-w-0 flex-[1_1_14rem] border border-muted bg-muted px-4 py-3.5 font-inherit text-primary placeholder:text-secondary"
				type="email"
				name="email"
				placeholder="Enter your email here"
				autocomplete="email"
			/>
			<button
				type="button"
				class="inline-block cursor-pointer border border-primary bg-primary px-7 py-3.5 text-center font-sans text-[0.8125rem] font-semibold uppercase tracking-[0.08em] text-background no-underline"
			>
				Subscribe
			</button>
		</div>
	</section>

	<footer class="mx-auto max-w-6xl border-t border-muted px-[clamp(1rem,4vw,3rem)] pb-8 pt-[clamp(2.5rem,6vw,4rem)]">
		<div class="mb-10 flex flex-wrap items-center justify-between gap-4">
			<p class="m-0 font-serif text-[1.35rem] font-bold">Rad Plants</p>
			<label>
				<span class="sr-only">Currency</span>
				<select
					class="border border-muted bg-background px-2 py-[0.4rem] pe-8 font-inherit text-primary"
					name="currency"
					aria-label="Currency"
				>
					<option value="eur" selected>EUR</option>
					<option value="usd">USD</option>
					<option value="gbp">GBP</option>
				</select>
			</label>
		</div>
		<div class="mb-10 grid grid-cols-1 gap-8 min-[600px]:grid-cols-3">
			<div>
				<h3 class="mb-3 text-[0.8125rem] font-semibold uppercase tracking-[0.06em]">Connect</h3>
				<ul class="m-0 list-none p-0">
					<li class="mb-2">
						<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Instagram</a>
					</li>
					<li class="mb-2">
						<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Facebook</a>
					</li>
					<li class="mb-2">
						<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Pinterest</a>
					</li>
					<li class="mb-2">
						<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">YouTube</a>
					</li>
				</ul>
			</div>
			<div>
				<h3 class="mb-3 text-[0.8125rem] font-semibold uppercase tracking-[0.06em]">Resources</h3>
				<ul class="m-0 list-none p-0">
					<li class="mb-2">
						<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Return policy</a>
					</li>
					<li class="mb-2">
						<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Track an order</a>
					</li>
					<li class="mb-2">
						<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">FAQs</a>
					</li>
					<li class="mb-2">
						<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Privacy policy</a>
					</li>
				</ul>
			</div>
			<div>
				<h3 class="mb-3 text-[0.8125rem] font-semibold uppercase tracking-[0.06em]">About</h3>
				<ul class="m-0 list-none p-0">
					<li class="mb-2">
						<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Our story</a>
					</li>
					<li class="mb-2">
						<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Careers</a>
					</li>
					<li class="mb-2">
						<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Press</a>
					</li>
				</ul>
			</div>
		</div>
		<p class="m-0 text-center text-[0.8125rem] text-secondary">Designed by Slobodan Rad</p>
	</footer>
</main>
