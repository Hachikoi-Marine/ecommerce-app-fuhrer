---
---

<section
	id="newsletter"
	class="mx-auto max-w-2xl px-[clamp(1rem,4vw,3rem)] py-[clamp(3rem,8vw,5.5rem)] text-center"
	aria-labelledby="newsletter-heading"
>
	<h2 id="newsletter-heading" class="mb-7 font-serif text-[clamp(1.25rem,2.5vw,1.5rem)] font-semibold leading-snug">
		Get 15% off your next order, subscribe to our newsletter
	</h2>
	<div class="flex flex-wrap items-stretch justify-center gap-3" role="group" aria-label="Newsletter signup">
		<label class="sr-only" for="store-newsletter-email">Email</label>
		<input
			id="store-newsletter-email"
			class="min-w-0 flex-[1_1_14rem] border border-muted bg-muted px-4 py-3.5 font-inherit text-primary placeholder:text-secondary"
			type="email"
			name="email"
			placeholder="Enter your email here"
			autocomplete="email"
		/>
		<button
			type="button"
			class="inline-block cursor-pointer border border-primary bg-primary px-7 py-3.5 text-center font-sans text-[0.8125rem] font-semibold uppercase tracking-[0.08em] text-background no-underline"
		>
			Subscribe
		</button>
	</div>
</section>

<footer class="mx-auto max-w-6xl border-t border-muted px-[clamp(1rem,4vw,3rem)] pb-8 pt-[clamp(2.5rem,6vw,4rem)]">
	<div class="mb-10 flex flex-wrap items-center justify-between gap-4">
		<p class="m-0 font-serif text-[1.35rem] font-bold">Rad Atelier</p>
		<label>
			<span class="sr-only">Currency</span>
			<select
				class="border border-muted bg-background px-2 py-[0.4rem] pe-8 font-inherit text-primary"
				name="currency"
				aria-label="Currency"
			>
				<option value="eur" selected>EUR</option>
				<option value="usd">USD</option>
				<option value="gbp">GBP</option>
			</select>
		</label>
	</div>
	<div class="mb-10 grid grid-cols-1 gap-8 min-[600px]:grid-cols-3">
		<div>
			<h3 class="mb-3 text-[0.8125rem] font-semibold uppercase tracking-[0.06em]">Connect</h3>
			<ul class="m-0 list-none p-0">
				<li class="mb-2">
					<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Instagram</a>
				</li>
				<li class="mb-2">
					<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Facebook</a>
				</li>
				<li class="mb-2">
					<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Pinterest</a>
				</li>
				<li class="mb-2">
					<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">YouTube</a>
				</li>
			</ul>
		</div>
		<div>
			<h3 class="mb-3 text-[0.8125rem] font-semibold uppercase tracking-[0.06em]">Resources</h3>
			<ul class="m-0 list-none p-0">
				<li class="mb-2">
					<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Return policy</a>
				</li>
				<li class="mb-2">
					<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Track an order</a>
				</li>
				<li class="mb-2">
					<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">FAQs</a>
				</li>
				<li class="mb-2">
					<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Privacy policy</a>
				</li>
			</ul>
		</div>
		<div>
			<h3 class="mb-3 text-[0.8125rem] font-semibold uppercase tracking-[0.06em]">About</h3>
			<ul class="m-0 list-none p-0">
				<li class="mb-2">
					<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Our story</a>
				</li>
				<li class="mb-2">
					<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Careers</a>
				</li>
				<li class="mb-2">
					<a class="text-[0.9375rem] text-secondary no-underline hover:text-primary hover:underline" href="#">Press</a>
				</li>
			</ul>
		</div>
	</div>
	<p class="m-0 text-center text-[0.8125rem] text-secondary">Designed by Slobodan Rad</p>
</footer>
