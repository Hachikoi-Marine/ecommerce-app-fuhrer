---
export const prerender = false;

import SiteLayout from '../../layouts/SiteLayout.astro';
---

<SiteLayout title="Your profile — Rad Atelier">
	<main class="mx-auto max-w-xl px-[clamp(1rem,4vw,2rem)] py-[clamp(2rem,6vw,4rem)]">
		<h1 class="mb-4 font-serif text-[clamp(1.75rem,3vw,2.25rem)]">Your profile</h1>
		<p class="mb-6 leading-relaxed text-secondary">
			This page is only visible when you are signed in. Use Log out in the header to clear your session.
		</p>
		<p>
			<a class="text-primary" href="/">Continue shopping</a>
		</p>
	</main>
</SiteLayout>
