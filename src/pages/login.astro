---
export const prerender = false;

import SiteLayout from '../layouts/SiteLayout.astro';

const error = Astro.url.searchParams.get('error');
const errorMessage =
	error === 'missing'
		? 'Enter both email and password.'
		: error === 'invalid'
			? 'Email or password was not recognized.'
			: error
				? 'Something went wrong. Try again.'
				: null;
---

<SiteLayout title="Log in — Rad Atelier">
	<main class="mx-auto max-w-[22rem] px-4 py-[clamp(2rem,6vw,4rem)]">
		<h1 class="mb-3 font-serif text-[1.75rem]">Log in</h1>
		<p class="mb-6 text-[0.9375rem] text-secondary">Sign in with your Supabase account. You will be redirected to the homepage.</p>
		{errorMessage && <p class="mb-4 text-[0.9375rem] text-primary" role="alert">{errorMessage}</p>}
		<form class="flex flex-col gap-5" method="post" action="/api/auth/supabase-login">
			<label class="flex flex-col gap-1.5">
				<span class="text-sm font-medium">Email</span>
				<input
					class="border border-muted bg-background px-3 py-2.5 font-inherit text-primary"
					type="email"
					name="email"
					required
					autocomplete="email"
				/>
			</label>
			<label class="flex flex-col gap-1.5">
				<span class="text-sm font-medium">Password</span>
				<input
					class="border border-muted bg-background px-3 py-2.5 font-inherit text-primary"
					type="password"
					name="password"
					required
					autocomplete="current-password"
				/>
			</label>
			<button
				type="submit"
				class="cursor-pointer border border-primary bg-primary px-5 py-3.5 font-sans text-[0.8125rem] font-semibold uppercase tracking-[0.06em] text-background"
			>
				Sign in
			</button>
		</form>
		<p class="mt-6 text-[0.9375rem]">
			<a class="text-secondary" href="/">Back to home</a>
		</p>
	</main>
</SiteLayout>
