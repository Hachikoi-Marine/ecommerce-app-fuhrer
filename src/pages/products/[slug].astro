---
import SiteLayout from '../../layouts/SiteLayout.astro';
import StoreChromeFooter from '../../components/store/StoreChromeFooter.astro';
import { formatPrice, getProductBySlug, productSlugs } from '../../lib/catalog';

export function getStaticPaths() {
	return productSlugs.map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug;
const product = slug ? getProductBySlug(slug) : undefined;
if (!product) {
	return Astro.redirect('/');
}

const priceLabel = formatPrice(product);
const thumbSources = product.thumbnails.length ? product.thumbnails : [product.imageMain];
---

<SiteLayout variant="store" title={`${product.title} — Rad Atelier`}>
	<main class="px-[clamp(1rem,4vw,3rem)] pb-0 pt-[clamp(1.5rem,4vw,3rem)]">
		<div class="mx-auto grid max-w-6xl items-start gap-[clamp(2rem,5vw,4rem)] md:grid-cols-[minmax(0,1.05fr)_minmax(0,1fr)]">
			<div class="flex flex-col gap-4">
				<div class="aspect-[4/5] max-h-[min(80vh,640px)] w-full overflow-hidden border border-muted bg-background">
					<img
						id="product-main-img"
						class="block size-full object-cover"
						src={product.imageMain}
						alt={product.imageAlt}
						width="900"
						height="1120"
					/>
				</div>
				<div class="flex flex-wrap gap-3" role="tablist" aria-label="Product images">
					{
						thumbSources.map((src, i) => (
							<button
								type="button"
								class="size-[5.5rem] shrink-0 cursor-pointer overflow-hidden border-2 border-transparent bg-background p-0 aria-pressed:border-primary"
								data-product-thumb
								data-src={src}
								aria-label={`View image ${i + 1}`}
								aria-pressed={i === 0 ? 'true' : 'false'}
							>
								<img class="block size-full object-cover" src={src} alt="" width="200" height="200" loading="lazy" />
							</button>
						))
					}
				</div>
			</div>
			<div class="pt-2">
				{product.soldOut && (
					<span class="mb-4 inline-block bg-primary px-2.5 py-[0.35rem] text-[0.6875rem] font-bold uppercase tracking-[0.06em] text-background">
						Sold out
					</span>
				)}
				<h1 class="mb-2 font-serif text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-tight">{product.title}</h1>
				<p class="mb-8 font-serif text-[clamp(1.75rem,3vw,2.25rem)] font-semibold">{priceLabel}</p>
				<div class="mb-7">
					<span class="mb-2 block text-[0.8125rem] font-medium text-primary">Quantity</span>
					<div class="inline-flex items-center border border-muted bg-background">
						<button
							type="button"
							class="size-11 cursor-pointer border-0 bg-transparent text-xl text-primary disabled:cursor-not-allowed disabled:opacity-[0.35]"
							id="qty-minus"
							aria-label="Decrease quantity"
						>
							−
						</button>
						<span class="min-w-10 text-center text-base font-medium" id="qty-value">1</span>
						<button
							type="button"
							class="size-11 cursor-pointer border-0 bg-transparent text-xl text-primary disabled:cursor-not-allowed disabled:opacity-[0.35]"
							id="qty-plus"
							aria-label="Increase quantity"
						>
							+
						</button>
					</div>
				</div>
				<button
					type="button"
					class="w-full max-w-[22rem] cursor-pointer border border-primary bg-primary px-6 py-4 font-sans text-[0.8125rem] font-bold uppercase tracking-[0.1em] text-background hover:opacity-[0.92] disabled:cursor-not-allowed disabled:opacity-[0.45]"
					id="add-to-cart"
					disabled={product.soldOut}
				>
					Add to cart
				</button>
			</div>
		</div>
	</main>
	<StoreChromeFooter />
</SiteLayout>

<script define:vars={{ soldOut: product.soldOut, maxQty: Math.max(1, product.stock) }}>
	const mainImg = document.getElementById('product-main-img');
	const qtyValue = document.getElementById('qty-value');
	const minus = document.getElementById('qty-minus');
	const plus = document.getElementById('qty-plus');
	const thumbButtons = document.querySelectorAll('[data-product-thumb]');

	let qty = 1;
	const cap = soldOut ? 1 : maxQty;

	if (soldOut) {
		if (minus) {
			minus.disabled = true;
		}
		if (plus) {
			plus.disabled = true;
		}
	}

	function setQty(next) {
		qty = Math.min(cap, Math.max(1, next));
		if (qtyValue) {
			qtyValue.textContent = String(qty);
		}
	}

	function syncThumbActive(activeBtn) {
		thumbButtons.forEach((btn) => {
			btn.setAttribute('aria-pressed', btn === activeBtn ? 'true' : 'false');
		});
	}

	thumbButtons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const src = btn.getAttribute('data-src');
			if (src && mainImg) {
				mainImg.setAttribute('src', src);
			}
			syncThumbActive(btn);
		});
	});

	minus?.addEventListener('click', () => {
		if (!soldOut) {
			setQty(qty - 1);
		}
	});
	plus?.addEventListener('click', () => {
		if (!soldOut) {
			setQty(qty + 1);
		}
	});
</script>
