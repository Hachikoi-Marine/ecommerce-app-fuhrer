---
export const prerender = false;

import SuperAdminLayout from '../../../layouts/SuperAdminLayout.astro';
---

<SuperAdminLayout title="Superadmin profile">
	<main class="mx-auto max-w-xl px-[clamp(1rem,4vw,2rem)] py-[clamp(2rem,6vw,4rem)]">
		<h1 class="mb-4 font-serif text-[clamp(1.75rem,3vw,2.25rem)]">Superadmin profile</h1>
		<p class="m-0 leading-relaxed text-secondary">You are signed in as the configured superadmin user.</p>
	</main>
</SuperAdminLayout>
