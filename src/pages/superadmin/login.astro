---
export const prerender = false;

import SuperAdminLayout from '../../layouts/SuperAdminLayout.astro';

const rawReturn = Astro.url.searchParams.get('returnTo') ?? '/superadmin/profile';
const returnTo =
	rawReturn.startsWith('/superadmin/') && !rawReturn.startsWith('//')
		? rawReturn
		: '/superadmin/profile';
const error = Astro.url.searchParams.get('error');
const errorMessage =
	error === 'missing'
		? 'Enter both email and password.'
		: error === 'invalid'
			? 'Email or password was not recognized.'
			: error === 'forbidden'
				? 'This account is not allowed to use superadmin.'
				: error === 'config'
					? 'Superadmin is not configured (set SUPERADMIN_EMAIL in your environment).'
					: error
						? 'Something went wrong. Try again.'
						: null;
---

<SuperAdminLayout title="Superadmin — Sign in">
	<main class="auth-main">
		<h1 class="font-serif page-title">Superadmin sign in</h1>
		<p class="lede">Restricted access. After sign in you will go to your superadmin profile.</p>
		{errorMessage && <p class="error" role="alert">{errorMessage}</p>}
		<form class="auth-form" method="post" action="/api/auth/superadmin-login">
			<input type="hidden" name="returnTo" value={returnTo} />
			<label class="field">
				<span class="label">Email</span>
				<input class="input" type="email" name="email" required autocomplete="username" />
			</label>
			<label class="field">
				<span class="label">Password</span>
				<input class="input" type="password" name="password" required autocomplete="current-password" />
			</label>
			<button type="submit" class="btn btn-solid">Sign in</button>
		</form>
	</main>
</SuperAdminLayout>

<style>
	.auth-main {
		max-width: 22rem;
		margin: 0 auto;
		padding: clamp(2rem, 6vw, 4rem) 1rem;
	}

	.font-serif {
		font-family: var(--font-serif);
	}

	.page-title {
		font-size: 1.75rem;
		margin: 0 0 0.75rem;
	}

	.lede {
		margin: 0 0 1.5rem;
		color: var(--color-secondary);
		font-size: 0.9375rem;
	}

	.error {
		margin: 0 0 1rem;
		font-size: 0.9375rem;
		color: var(--color-primary);
	}

	.auth-form {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.field {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.label {
		font-size: 0.875rem;
		font-weight: 500;
	}

	.input {
		font: inherit;
		padding: 0.65rem 0.75rem;
		border: 1px solid var(--color-muted);
		background: var(--color-background);
		color: var(--color-primary);
	}

	.btn {
		display: inline-block;
		padding: 0.875rem 1.25rem;
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		border: 1px solid var(--color-primary);
		cursor: pointer;
	}

	.btn-solid {
		background: var(--color-primary);
		color: var(--color-background);
	}
</style>
