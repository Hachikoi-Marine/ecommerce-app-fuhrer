---
import SiteLayout from '../../layouts/SiteLayout.astro';
import StoreChromeFooter from '../../components/store/StoreChromeFooter.astro';
import { formatPrice, getProductBySlug, productSlugs } from '../../lib/catalog';

export function getStaticPaths() {
	return productSlugs.map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug;
const product = slug ? getProductBySlug(slug) : undefined;
if (!product) {
	return Astro.redirect('/');
}

const priceLabel = formatPrice(product);
const thumbSources = product.thumbnails.length ? product.thumbnails : [product.imageMain];
---

<SiteLayout variant="store" title={`${product.title} — Rad Plants`}>
	<main class="product-page">
		<div class="product-inner">
			<div class="product-gallery">
				<div class="product-main-frame">
					<img
						id="product-main-img"
						class="product-main-img"
						src={product.imageMain}
						alt={product.imageAlt}
						width="900"
						height="1120"
					/>
				</div>
				<div class="product-thumbs" role="tablist" aria-label="Product images">
					{
						thumbSources.map((src, i) => (
							<button
								type="button"
								class:list={['thumb-btn', { 'is-active': i === 0 }]}
								data-src={src}
								aria-label={`View image ${i + 1}`}
								aria-pressed={i === 0 ? 'true' : 'false'}
							>
								<img src={src} alt="" width="200" height="200" loading="lazy" />
							</button>
						))
					}
				</div>
			</div>
			<div class="product-info">
				{product.soldOut && <span class="stock-badge">Sold out</span>}
				<h1 class="product-title font-serif">{product.title}</h1>
				<p class="product-price font-serif">{priceLabel}</p>
				<div class="qty-block">
					<span class="qty-label">Quantity</span>
					<div class="qty-control">
						<button type="button" class="qty-btn" id="qty-minus" aria-label="Decrease quantity">
							−
						</button>
						<span class="qty-value" id="qty-value">1</span>
						<button type="button" class="qty-btn" id="qty-plus" aria-label="Increase quantity">
							+
						</button>
					</div>
				</div>
				<button
					type="button"
					class="btn-add-cart"
					id="add-to-cart"
					disabled={product.soldOut}
				>
					Add to cart
				</button>
			</div>
		</div>
	</main>
	<StoreChromeFooter />
</SiteLayout>

<script define:vars={{ soldOut: product.soldOut, maxQty: Math.max(1, product.stock) }}>
	const mainImg = document.getElementById('product-main-img');
	const qtyValue = document.getElementById('qty-value');
	const minus = document.getElementById('qty-minus');
	const plus = document.getElementById('qty-plus');
	const thumbButtons = document.querySelectorAll('.thumb-btn');

	let qty = 1;
	const cap = soldOut ? 1 : maxQty;

	if (soldOut) {
		if (minus) {
			minus.disabled = true;
		}
		if (plus) {
			plus.disabled = true;
		}
	}

	function setQty(next) {
		qty = Math.min(cap, Math.max(1, next));
		if (qtyValue) {
			qtyValue.textContent = String(qty);
		}
	}

	function syncThumbActive(activeBtn) {
		thumbButtons.forEach((btn) => {
			btn.classList.toggle('is-active', btn === activeBtn);
			btn.setAttribute('aria-pressed', btn === activeBtn ? 'true' : 'false');
		});
	}

	thumbButtons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const src = btn.getAttribute('data-src');
			if (src && mainImg) {
				mainImg.setAttribute('src', src);
			}
			syncThumbActive(btn);
		});
	});

	minus?.addEventListener('click', () => {
		if (!soldOut) {
			setQty(qty - 1);
		}
	});
	plus?.addEventListener('click', () => {
		if (!soldOut) {
			setQty(qty + 1);
		}
	});
</script>

<style>
	.product-page {
		padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 3rem) 0;
	}

	.product-inner {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: start;
		max-width: 72rem;
		margin: 0 auto;
	}

	@media (max-width: 900px) {
		.product-inner {
			grid-template-columns: 1fr;
		}
	}

	.font-serif {
		font-family: var(--font-serif);
	}

	.product-gallery {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.product-main-frame {
		background: var(--color-background);
		border: 1px solid var(--color-muted);
		overflow: hidden;
		aspect-ratio: 4 / 5;
		max-height: min(80vh, 640px);
	}

	.product-main-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.product-thumbs {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.thumb-btn {
		padding: 0;
		border: 2px solid transparent;
		background: var(--color-background);
		cursor: pointer;
		width: 5.5rem;
		height: 5.5rem;
		overflow: hidden;
		flex-shrink: 0;
	}

	.thumb-btn img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.thumb-btn.is-active {
		border-color: var(--color-primary);
	}

	.product-info {
		padding-top: 0.5rem;
	}

	.stock-badge {
		display: inline-block;
		padding: 0.35rem 0.6rem;
		font-size: 0.6875rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		background: var(--color-primary);
		color: var(--color-background);
		margin-bottom: 1rem;
	}

	.product-title {
		font-size: clamp(2rem, 4vw, 2.75rem);
		font-weight: 600;
		line-height: 1.1;
		margin: 0 0 0.5rem;
	}

	.product-price {
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		font-weight: 600;
		margin: 0 0 2rem;
	}

	.qty-block {
		margin-bottom: 1.75rem;
	}

	.qty-label {
		display: block;
		font-size: 0.8125rem;
		font-weight: 500;
		margin-bottom: 0.5rem;
		color: var(--color-primary);
	}

	.qty-control {
		display: inline-flex;
		align-items: center;
		border: 1px solid var(--color-muted);
		background: var(--color-background);
	}

	.qty-btn {
		width: 2.75rem;
		height: 2.75rem;
		border: none;
		background: none;
		font-size: 1.25rem;
		line-height: 1;
		cursor: pointer;
		color: var(--color-primary);
	}

	.qty-btn:disabled {
		opacity: 0.35;
		cursor: not-allowed;
	}

	.qty-value {
		min-width: 2.5rem;
		text-align: center;
		font-size: 1rem;
		font-weight: 500;
	}

	.btn-add-cart {
		width: 100%;
		max-width: 22rem;
		padding: 1rem 1.5rem;
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		background: var(--color-primary);
		color: var(--color-background);
		border: 1px solid var(--color-primary);
		cursor: pointer;
	}

	.btn-add-cart:disabled {
		opacity: 0.45;
		cursor: not-allowed;
	}

	.btn-add-cart:not(:disabled):hover {
		opacity: 0.92;
	}
</style>
